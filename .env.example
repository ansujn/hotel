# ==== SHARED ====
APP_ENV=local                           # local | staging | production
LOG_LEVEL=debug

# ==== API (Go) ====
API_PORT=8080
API_BASE_URL=http://localhost:8080
JWT_SECRET=replace-with-openssl-rand-base64-32
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=720h

# Postgres (Neon for prod/staging, local Docker for dev)
DATABASE_URL=postgres://vik:vik@localhost:5432/vik?sslmode=disable

# Mux
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_PRIVATE=
MUX_WEBHOOK_SECRET=

# MSG91 (SMS/OTP — India DLT registered)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=VIKTHR
MSG91_OTP_TEMPLATE_ID=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM=no-reply@viktheatre.in

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Anthropic (Claude for captions + clip selection)
ANTHROPIC_API_KEY=

# Buffer or Metricool (social scheduling)
BUFFER_ACCESS_TOKEN=

# Observability
SENTRY_DSN=
POSTHOG_KEY=

# ==== WEB (Next.js) ====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_SENTRY_DSN=

# ==== MOBILE (Flutter) — set via --dart-define ====
# FLUTTER_API_BASE_URL=http://localhost:8080
