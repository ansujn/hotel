# ==== SHARED ====
APP_ENV=local                           # local | staging | production
LOG_LEVEL=debug

# ==== API (Go) ====
API_PORT=8080
APP_BASE_URL=http://localhost:3000
JWT_SECRET=replace-with-openssl-rand-base64-32
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=720h

# Postgres (Neon for prod/staging, local Docker for dev)
DATABASE_URL=postgres://vik:vik@localhost:5432/vik?sslmode=disable

# Mux
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_PRIVATE=
MUX_WEBHOOK_SECRET=

# Brevo — transactional email (welcome + password reset). 300/day free.
# Leave BREVO_API_KEY empty locally: reset links will just print to the API
# server logs so you can click them by hand.
BREVO_API_KEY=
MAIL_FROM_EMAIL=no-reply@example.com
MAIL_FROM_NAME=Vik Theatre

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Anthropic (Claude for captions + clip selection)
ANTHROPIC_API_KEY=

# Buffer or Metricool (social scheduling)
BUFFER_ACCESS_TOKEN=

# Observability
SENTRY_DSN=
POSTHOG_KEY=

# ==== WEB (Next.js) ====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_SENTRY_DSN=
