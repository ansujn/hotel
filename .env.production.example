# .env.production — TEMPLATE (do NOT commit the filled version; .env.production is gitignored)
#
# Usage: cp .env.production.example .env.production, fill in values from each provider,
# then run scripts/set-fly-secrets.sh and scripts/set-vercel-env.sh.

# ==== SHARED ====
APP_ENV=production
LOG_LEVEL=info

# ==== API (Go / Fly.io) ====
API_PORT=8080
APP_BASE_URL=https://victor.saudagars.org
JWT_SECRET=                              # generate: openssl rand -base64 48
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=720h

# Postgres — Neon (ap-south-1 preferred, ap-southeast-1 fallback)
# From Neon dashboard → Connection string → "Pooled connection" (pgbouncer). Must include ?sslmode=require
DATABASE_URL=postgres://USER:PASS@ep-xxx-pooler.ap-south-1.aws.neon.tech/viktheatre?sslmode=require

# Mux — https://dashboard.mux.com → Settings → Access Tokens
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=                      # Settings → Signing Keys (for signed playback URLs)
MUX_SIGNING_KEY_PRIVATE=                 # base64-encoded PEM
MUX_WEBHOOK_SECRET=                      # Settings → Webhooks → target https://api.viktheatre.in/v1/webhooks/mux

# Brevo — https://app.brevo.com/settings/keys/api (300 emails/day free tier)
# The FROM address MUST be from a domain you have verified in Brevo (DKIM + SPF).
# For Vik Theatre, verify "saudagars.org" (or a subdomain) in Brevo → Senders & IP.
BREVO_API_KEY=
MAIL_FROM_EMAIL=no-reply@saudagars.org
MAIL_FROM_NAME=Vik Theatre

# Razorpay — https://dashboard.razorpay.com → Settings → API Keys (use LIVE, not TEST).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=                 # Settings → Webhooks → target https://api.viktheatre.in/v1/webhooks/razorpay

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Buffer — https://publish.buffer.com/account/apps
BUFFER_ACCESS_TOKEN=

# Observability
SENTRY_DSN=                              # Sentry project → Settings → Client Keys (DSN)
POSTHOG_KEY=                             # PostHog project → Project Settings → Project API Key

# ==== WEB (Next.js / Vercel) — set via Vercel dashboard OR scripts/set-vercel-env.sh ====
NEXT_PUBLIC_API_BASE_URL=https://api.viktheatre.in
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_SENTRY_DSN=
